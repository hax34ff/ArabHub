local function Create(className, props, children)
    local inst = Instance.new(className)
    for prop, value in pairs(props or {}) do
        inst[prop] = value
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

local function Tween(inst, props, time, style, direction)
    local tween = TweenService:Create(
        inst,
        TweenInfo.new(
            time or Theme.TweenTime,
            style or Theme.TweenStyle,
            direction or Theme.TweenDirection
        ),
        props
    )
    tween:Play()
    return tween
end

local function MakeDraggable(topbar, frame)
    local dragging = false
    local dragStart, startPos

    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    topbar.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

local function AddCorner(inst, radius)
    return Create("UICorner", {
        CornerRadius = UDim.new(0, radius or 6),
        Parent = inst
    })
end

local function AddStroke(inst, color, thickness)
    return Create("UIStroke", {
        Color = color or Theme.Stroke,
        Thickness = thickness or 1,
        Transparency = 0.3,
        Parent = inst
    })
end

local function AddPadding(inst, all)
    return Create("UIPadding", {
        PaddingTop = UDim.new(0, all or 8),
        PaddingBottom = UDim.new(0, all or 8),
        PaddingLeft = UDim.new(0, all or 8),
        PaddingRight = UDim.new(0, all or 8),
        Parent = inst
    })
end

