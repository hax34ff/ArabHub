            end)

            return Btn
        end

        --------------------------------------------------
        -- TOGGLE
        --------------------------------------------------
        function Tab:CreateToggle(config)
            config = config or {}
            local State = config.Default or false

            local Holder = Create("Frame", {
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = Theme.Card,
                BorderSizePixel = 0,
                Parent = Page
            })
            AddCorner(Holder, 6)
            AddStroke(Holder, Theme.Stroke, 1)

            Create("TextLabel", {
                Text = config.Text or "Toggle",
                Font = Theme.Font,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -70, 1, 0),
                Position = UDim2.fromOffset(12, 0),
                Parent = Holder
            })

            -- Switch track
            local Track = Create("Frame", {
                Size = UDim2.fromOffset(44, 22),
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -12, 0.5, 0),
                BackgroundColor3 = Theme.Background,
                BorderSizePixel = 0,
                Parent = Holder
            })
            AddCorner(Track, 11)
            local TrackStroke = AddStroke(Track, Theme.Stroke, 1)

            -- Fill (the "====" part)
            local Fill = Create("Frame", {
                Size = UDim2.new(0, State and 44 or 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel = 0,
                Parent = Track
            })
            AddCorner(Fill, 11)

            -- Knob
            local Knob = Create("Frame", {
                Size = UDim2.fromOffset(16, 16),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = State and UDim2.new(1, -11, 0.5, 0) or UDim2.new(0, 11, 0.5, 0),
                BackgroundColor3 = Theme.Text,
                BorderSizePixel = 0,
                Parent = Track
            })
            AddCorner(Knob, 8)

            local Click = Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                Parent = Holder
            })

            local function Render()
                if State then
                    Tween(Fill, {Size = UDim2.new(0, 44, 1, 0)}, 0.22)
                    Tween(Knob, {Position = UDim2.new(1, -11, 0.5, 0), BackgroundColor3 = Theme.Background}, 0.22)
                    Tween(TrackStroke, {Color = Theme.Accent}, 0.22)
                else
                    Tween(Fill, {Size = UDim2.new(0, 0, 1, 0)}, 0.22)
                    Tween(Knob, {Position = UDim2.new(0, 11, 0.5, 0), BackgroundColor3 = Theme.Text}, 0.22)
                    Tween(TrackStroke, {Color = Theme.Stroke}, 0.22)
                end
            end
            Render()

            Click.MouseButton1Click:Connect(function()
                State = not State
                Render()
                if config.Callback then config.Callback(State) end
            end)

            return {
                Set = function(_, value)
                    State = value
                    Render()
                    if config.Callback then config.Callback(State) end
                end,
                Get = function() return State end
            }
        end

        --------------------------------------------------
        -- SLIDER
        --------------------------------------------------
        function Tab:CreateSlider(config)
            config = config or {}
            local Min = config.Min or 0
            local Max = config.Max or 100
            local Value = math.clamp(config.Default or Min, Min, Max)

            local Holder = Create("Frame", {
                Size = UDim2.new(1, 0, 0, 50),
                BackgroundColor3 = Theme.Card,
                BorderSizePixel = 0,
                Parent = Page
            })
            AddCorner(Holder, 6)
            AddStroke(Holder, Theme.Stroke, 1)
            AddPadding(Holder, 10)

            local Label = Create("TextLabel", {
                Text = config.Text or "Slider",
                Font = Theme.Font,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -50, 0, 16),
                Parent = Holder
            })

            local ValueLabel = Create("TextLabel", {
                Text = tostring(Value),
                Font = Theme.FontBold,
                TextSize = 12,
                TextColor3 = Theme.Accent,
                TextXAlignment = Enum.TextXAlignment.Right,
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 50, 0, 16),
                Position = UDim2.new(1, -50, 0, 0),
                Parent = Holder
            })

            local Track = Create("Frame", {
                Size = UDim2.new(1, 0, 0, 6),
                Position = UDim2.fromOffset(0, 28),
                BackgroundColor3 = Theme.Background,
                BorderSizePixel = 0,
                Parent = Holder
            })
            AddCorner(Track, 3)
            AddStroke(Track, Theme.Stroke, 1)

            local Fill = Create("Frame", {
                Size = UDim2.new((Value - Min) / (Max - Min), 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel = 0,
                Parent = Track
            })
            AddCorner(Fill, 3)

            local Knob = Create("Frame", {
                Size = UDim2.fromOffset(14, 14),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new((Value - Min) / (Max - Min), 0, 0.5, 0),
                BackgroundColor3 = Theme.AccentHover,
                BorderSizePixel = 0,
                Parent = Track
            })
            AddCorner(Knob, 7)

            local Dragging = false

            local function UpdateFromPos(input)
                local relative = math.clamp(
                    (input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X,
                    0, 1
                )
                Value = math.floor(Min + (Max - Min) * relative)
                local pct = (Value - Min) / (Max - Min)
                Fill.Size = UDim2.new(pct, 0, 1, 0)
                Knob.Position = UDim2.new(pct, 0, 0.5, 0)
                ValueLabel.Text = tostring(Value)
                if config.Callback then config.Callback(Value) end
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                    Dragging = true
                    UpdateFromPos(input)
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                    or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateFromPos(input)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                    Dragging = false
                end
            end)

            return {
                Set = function(_, newValue)
                    Value = math.clamp(newValue, Min, Max)
                    local pct = (Value - Min) / (Max - Min)
                    Tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.15)
                    Tween(Knob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.15)
                    ValueLabel.Text = tostring(Value)
                    if config.Callback then config.Callback(Value) end
                end,
                Get = function() return Value end
            }
        end

        --------------------------------------------------
        -- DROPDOWN
        --------------------------------------------------
        function Tab:CreateDropdown(config)
            config = config or {}
            local Options = config.Options or {}
            local Selected = config.Default or Options[1] or "None"
            local Open = false

            local Holder = Create("Frame", {
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = Theme.Card,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                ZIndex = 2,
                Parent = Page
            })
            AddCorner(Holder, 6)
            local HolderStroke = AddStroke(Holder, Theme.Stroke, 1)

            Create("TextLabel", {
                Text = config.Text or "Dropdown",
                Font = Theme.Font,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Size = UDim2.new(0.5, -12, 0, 36),
                Position = UDim2.fromOffset(12, 0),
                ZIndex = 2,
                Parent = Holder
            })

            local SelectedLabel = Create("TextLabel", {
                Text = Selected,
                Font = Theme.FontBold,
                TextSize = 12,
                TextColor3 = Theme.Accent,
                TextXAlignment = Enum.TextXAlignment.Right,
                BackgroundTransparency = 1,
                Size = UDim2.new(0.5, -30, 0, 36),
                Position = UDim2.new(0.5, 0, 0, 0),
                ZIndex = 2,
                Parent = Holder
            })

            local ArrowHolder = Create("Frame", {
                Size = UDim2.fromOffset(20, 36),
                Position = UDim2.new(1, -24, 0, 0),
                BackgroundTransparency = 1,
                ZIndex = 2,
                Parent = Holder
            })

            -- Drawn triangle (avoids font-glyph rendering issues)
            local Arrow = Create("Frame", {
                Name = "ArrowShape",
                Size = UDim2.fromOffset(8, 8),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.fromScale(0.5, 0.5),
                Rotation = 45,
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel = 0,
                ZIndex = 2,
                Parent = ArrowHolder
            })
            AddCorner(Arrow, 2)

            local Click = Create("TextButton", {
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 3,
                Parent = Holder
            })

            -- Options list container
            local ListFrame = Create("Frame", {
                Size = UDim2.new(1, -8, 0, 0),
                Position = UDim2.fromOffset(4, 40),
                BackgroundColor3 = Theme.Background,
                BorderSizePixel = 0,
                ZIndex = 2,
                Parent = Holder
            })
            AddCorner(ListFrame, 5)
            AddStroke(ListFrame, Theme.Stroke, 1)

            local SearchBox = Create("TextBox", {
                Size = UDim2.new(1, -10, 0, 24),
                Position = UDim2.fromOffset(5, 5),
                BackgroundColor3 = Theme.Card,
                Text = "",
                PlaceholderText = "Search...",
                PlaceholderColor3 = Theme.SubText,
                TextColor3 = Theme.Text,
                Font = Theme.Font,
                TextSize = 12,
                ClearTextOnFocus = false,
                ZIndex = 3,
                Parent = ListFrame
            })
            AddCorner(SearchBox, 4)
            AddPadding(SearchBox, 6)

            local OptionsScroll = Create("ScrollingFrame", {
                Size = UDim2.new(1, -10, 1, -34),
                Position = UDim2.fromOffset(5, 32),
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                ScrollBarThickness = 3,
                ScrollBarImageColor3 = Theme.Accent,
                CanvasSize = UDim2.new(0, 0, 0, 0),
                AutomaticCanvasSize = Enum.AutomaticSize.Y,
                ZIndex = 3,
                Parent = ListFrame
            })
            local OptionsList = Create("UIListLayout", {
                Padding = UDim.new(0, 2),
                Parent = OptionsScroll
            })

            local OptionButtons = {}

            local function RefreshList(filter)
                filter = (filter or ""):lower()
                for _, btn in ipairs(OptionButtons) do
                    if filter == "" or btn.Name:lower():find(filter, 1, true) then
                        btn.Visible = true
                    else
                        btn.Visible = false
                    end
                end
            end

            local MaxListHeight = 110

            local function CloseList()
                Open = false
                Tween(ListFrame, {Size = UDim2.new(1, -8, 0, 0)}, 0.2)
                Tween(Holder, {Size = UDim2.new(1, 0, 0, 36)}, 0.2)
                Tween(Arrow, {Rotation = 45}, 0.2)
            end

            local function OpenList()
                Open = true
                local count = #Options
                local height = math.min(count * 28 + 40, MaxListHeight)
                Tween(Holder, {Size = UDim2.new(1, 0, 0, 36 + height + 6)}, 0.2)
                Tween(ListFrame, {Size = UDim2.new(1, -8, 0, height)}, 0.2)
                Tween(Arrow, {Rotation = 180}, 0.2)
            end

            local function SelectOption(opt)
                Selected = opt
                SelectedLabel.Text = opt
                for _, btn in ipairs(OptionButtons) do
                    if btn.Name == opt then
                        btn.BackgroundColor3 = Theme.Accent
                        btn.TextLabel.TextColor3 = Theme.Background
                    else
                        btn.BackgroundColor3 = Theme.Card
                        btn.TextLabel.TextColor3 = Theme.Text
                    end
                end
                if config.Callback then config.Callback(opt) end
            end

            local function CreateOptionButton(opt)
                local OptBtn = Create("Frame", {
                    Name = opt,
                    Size = UDim2.new(1, 0, 0, 26),
                    BackgroundColor3 = (opt == Selected) and Theme.Accent or Theme.Card,
                    BorderSizePixel = 0,
                    ZIndex = 4,
                    Parent = OptionsScroll
                })
                AddCorner(OptBtn, 4)

                local OptLabel = Create("TextLabel", {
                    Name = "TextLabel",
                    Text = opt,
                    Font = Theme.Font,
                    TextSize = 12,
                    TextColor3 = (opt == Selected) and Theme.Background or Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -10, 1, 0),
                    Position = UDim2.fromOffset(8, 0),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 4,
                    Parent = OptBtn
                })

                local OptClick = Create("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = "",
                    ZIndex = 5,
                    Parent = OptBtn
                })

                OptBtn.MouseEnter:Connect(function()
                    if opt ~= Selected then
                        Tween(OptBtn, {BackgroundColor3 = Color3.fromRGB(46, 36, 28)}, 0.1)
                    end
                end)
                OptBtn.MouseLeave:Connect(function()
                    if opt ~= Selected then
                        Tween(OptBtn, {BackgroundColor3 = Theme.Card}, 0.1)
                    end
                end)

                OptClick.MouseButton1Click:Connect(function()
                    SelectOption(opt)
                    CloseList()
                end)

                table.insert(OptionButtons, OptBtn)
            end

            for _, opt in ipairs(Options) do
                CreateOptionButton(opt)
            end

            SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
                RefreshList(SearchBox.Text)
            end)

            Click.MouseButton1Click:Connect(function()
                if Open then
                    CloseList()
                else
                    OpenList()
                end
            end)

            return {
                Set = function(_, opt) SelectOption(opt) end,
                Get = function() return Selected end,
                Refresh = function(_, newOptions)
                    Options = newOptions
                    for _, btn in ipairs(OptionButtons) do btn:Destroy() end
                    OptionButtons = {}
                    -- Reset selection if it no longer exists
                    local stillValid = false
                    for _, opt in ipairs(Options) do
                        if opt == Selected then stillValid = true end
                    end
                    if not stillValid then
                        Selected = Options[1] or "None"
                        SelectedLabel.Text = Selected
                    end
                    for _, opt in ipairs(Options) do
                        CreateOptionButton(opt)
                    end
                    -- Re-apply current search filter
                    RefreshList(SearchBox.Text)
                end
            }
        end

        --------------------------------------------------
        -- TEXTBOX
        --------------------------------------------------
        function Tab:CreateTextbox(config)
            config = config or {}

            local Holder = Create("Frame", {
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = Theme.Card,
                BorderSizePixel = 0,
                Parent = Page
            })
            AddCorner(Holder, 6)
            local Stroke = AddStroke(Holder, Theme.Stroke, 1)

            Create("TextLabel", {
                Text = config.Text or "",
                Font = Theme.Font,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Size = UDim2.new(0.4, 0, 1, 0),
                Position = UDim2.fromOffset(12, 0),
                Visible = config.Text ~= nil and config.Text ~= "",
                Parent = Holder
            })

            local Box = Create("TextBox", {
                Size = UDim2.new(0.6, -16, 1, -10),
                Position = UDim2.new(0.4, 0, 0, 5),
                AnchorPoint = Vector2.new(0, 0),
                BackgroundColor3 = Theme.Background,
                Text = config.Default or "",
                PlaceholderText = config.Placeholder or "Enter text...",
                PlaceholderColor3 = Theme.SubText,
                TextColor3 = Theme.Text,
                Font = Theme.Font,
                TextSize = 12,
                ClearTextOnFocus = false,
                Parent = Holder
            })
            AddCorner(Box, 5)
            AddPadding(Box, 6)
            local BoxStroke = AddStroke(Box, Theme.Stroke, 1)

            -- If no label text, let textbox take full width
            if config.Text == nil or config.Text == "" then
                Box.Size = UDim2.new(1, -16, 1, -10)
                Box.Position = UDim2.fromOffset(8, 5)
            end

            Box.Focused:Connect(function()
                Tween(BoxStroke, {Color = Theme.Accent, Transparency = 0}, 0.2)
            end)
            Box.FocusLost:Connect(function(enterPressed)
                Tween(BoxStroke, {Color = Theme.Stroke, Transparency = 0.3}, 0.2)
                if config.Callback then config.Callback(Box.Text, enterPressed) end
            end)

            return {
                Set = function(_, text) Box.Text = text end,
                Get = function() return Box.Text end
            }
        end

        return Tab
    end

    return Window
end

