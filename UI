            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible = false,
            Parent = Content
        })
        AddPadding(Page, 12)
        local PageList = Create("UIListLayout", {
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = Page
        })

        -- Hover / select behavior
        local function SetActive(active)
            if active then
                Tween(TabButton, {BackgroundColor3 = Theme.Card}, 0.15)
                Tween(Stroke, {Transparency = 0.3}, 0.15)
                Tween(Indicator, {Size = UDim2.new(0, 3, 0, 18)}, 0.2)
                Tween(TabButton.Label, {TextColor3 = Theme.Text}, 0.15)
            else
                Tween(TabButton, {BackgroundColor3 = Theme.Card}, 0.15)
                Tween(Stroke, {Transparency = 1}, 0.15)
                Tween(Indicator, {Size = UDim2.new(0, 3, 0, 0)}, 0.2)
                Tween(TabButton.Label, {TextColor3 = Theme.SubText}, 0.15)
            end
        end

        TabButton.MouseEnter:Connect(function()
            if Window._ActiveTab ~= Page then
                Tween(TabButton, {BackgroundColor3 = Theme.Card == Theme.Card and Color3.fromRGB(42, 33, 26) or Theme.Card}, 0.15)
            end
        end)
        TabButton.MouseLeave:Connect(function()
            if Window._ActiveTab ~= Page then
                Tween(TabButton, {BackgroundColor3 = Theme.Card}, 0.15)
            end
        end)

        TabButton.MouseButton1Click:Connect(function()
            for _, p in pairs(Window._TabPages) do
                p.Page.Visible = false
                p.SetActive(false)
            end
            Page.Visible = true
            SetActive(true)
            Window._ActiveTab = Page
        end)

        Window._TabPages[name] = {Page = Page, SetActive = SetActive}

        -- First tab auto-selects
        if Window._ActiveTab == nil then
            Page.Visible = true
            SetActive(true)
            Window._ActiveTab = Page
        end

